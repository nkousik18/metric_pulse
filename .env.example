# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3
S3_BUCKET_NAME=metric-pulse-data

# Redshift
REDSHIFT_HOST=your-cluster.xxxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_password

# SNS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:metric-pulse-alerts

# Detection
ANOMALY_THRESHOLD_ZSCORE=2.0
LOOKBACK_DAYS=30